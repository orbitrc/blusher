[options]
compression = "zstd"

[[resource]]
prefix = "/org.blusher.Blusher"
files = [
    { path = "close.svg" },
    { path = "maximize.svg" },
    { path = "restore.svg" },
    { path = "minimize.svg", compress = false },

    { path = "close.png" },
    { path = "maximize.png" },
    { path = "restore.png" },
    { path = "minimize.png" },
]
